{
  "name": "@pebble-guard/bot",
  "version": "1.0.0",
  "private": true,
  "description": "PebbleGuard Discord bot — moderation, tickets, verification, logging",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "pnpm build && node dist/index.js",
    "start": "node dist/index.js",
    "with-env": "dotenv -e ../../.env --",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@discordjs/collection": "^2.0.0",
    "@pebble-guard/database": "workspace:*",
    "@pebble-guard/shared": "workspace:*",
    "@sapphire/decorators": "^6.0.2",
    "@sapphire/discord.js-utilities": "^7.1.2",
    "@sapphire/framework": "^4.8.2",
    "@sapphire/plugin-hmr": "^2.0.3",
    "@sapphire/plugin-scheduled-tasks": "^9.0.0",
    "@sapphire/time-utilities": "^1.7.10",
    "@sapphire/utilities": "^3.13.0",
    "@t3-oss/env-core": "^0.7.1",
    "colorette": "^2.0.20",
    "discord.js": "^14.14.1",
    "ioredis": "^5.3.2",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4",
    "crypto": "^1.0.1",
    "bcryptjs": "^2.4.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@sapphire/ts-config": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.9.3",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "dotenv-cli": "^7.3.0",
    "typescript": "^5.3.2"
  }
}
