{
  "name": "pebble-guard",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.6.7",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev-bot": "pnpm -F @pebble-guard/bot dev",
    "dev-dashboard": "pnpm -F @pebble-guard/dashboard dev",
    "start": "turbo start",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "pnpm -F @pebble-guard/database migrate:deploy",
    "db:studio": "pnpm -F @pebble-guard/database studio",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,md,json}\" --ignore-path .gitignore",
    "lint": "turbo lint",
    "type-check": "turbo type-check"
  },
  "devDependencies": {
    "@manypkg/cli": "^0.21.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "turbo": "^1.10.16",
    "typescript": "^5.3.2"
  }
}
