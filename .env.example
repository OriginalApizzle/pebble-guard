# ===========================
# PEBBLE GUARD — Environment
# ===========================

# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/pebbleguard?schema=public"
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/pebbleguard_shadow?schema=public"

# REDIS
REDIS_URL="redis://localhost:6379"

# DISCORD BOT
DISCORD_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# NEXTAUTH (Dashboard)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_URL_INTERNAL="http://localhost:3000"

# DASHBOARD PUBLIC
NEXT_PUBLIC_INVITE_URL="https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&scope=bot%20applications.commands"
NEXT_PUBLIC_BOT_API_URL="http://localhost:4000"

# BOT API (internal tRPC bridge)
BOT_API_URL="http://localhost:4000"
BOT_API_SECRET="change-me-to-a-long-random-string"

# ENCRYPTION
ENCRYPTION_KEY="32-char-hex-string-for-aes-256"

# OPTIONAL: SMTP (for email verification)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
